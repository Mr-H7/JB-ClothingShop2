generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String @id @default(cuid())
  slugFR    String @unique
  slugEN    String @unique
  nameFR    String
  nameEN    String
  sortOrder Int    @default(0)

  products Product[]
}

model Product {
  id         String @id @default(cuid())
  slug       String @unique
  nameFR     String
  nameEN     String
  descFR     String @default("")
  descEN     String @default("")
  price      Int
  categoryId String
  materialFR String @default("")
  materialEN String @default("")
  originFR   String @default("")
  originEN   String @default("")
  careFR     String @default("")
  careEN     String @default("")
  tagFR      String @default("")
  tagEN      String @default("")
  imgUrl     String @default("")
  status     String @default("ACTIVE")

  category Category @relation(fields: [categoryId], references: [id])
}

model NewsletterLead {
  id        String   @id @default(cuid())
  email     String   @unique
  language  String   @default("FR")
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        String    @id @default(cuid())
  email     String
  phone     String    @default("")
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

model CollaborationSubmission {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String    @default("")
  type      String
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?
}
